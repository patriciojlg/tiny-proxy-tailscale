#!/data/data/com.termux/files/usr/bin/env bash
# Health check — tiny-proxy-tailscale
# Verifica conectividad Tailscale (app Play Store o CLI) + tinyproxy + red

set -uo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

OK=0
WARN=0
FAIL=0

log_ok()   { echo -e "${GREEN}✅${NC} $1"; ((OK++)); }
log_warn() { echo -e "${YELLOW}⚠️${NC}  $1"; ((WARN++)); }
log_fail() { echo -e "${RED}❌${NC} $1"; ((FAIL++)); }
log_info() { echo -e "${BLUE}ℹ️ ${NC} $1"; }

# ───────────────────────────────────────────────
echo ""
echo "══════════════════════════════════════════════════"
echo "         HEALTH CHECK — tiny-proxy-tailscale"
echo "══════════════════════════════════════════════════"
echo ""

# ─── 1. Tailscale VPN interface ─────────────────
TS_IF=""
TS_IP=""

if ip addr show tailscale0 >/dev/null 2>&1; then
    TS_IF="tailscale0"
    TS_IP=$(ip addr show tailscale0 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d/ -f1)
    log_ok "Tailscale interfaz detectada: ${TS_IF} (${TS_IP})"
elif ip addr show tun0 >/dev/null 2>&1; then
    TS_IP=$(ip addr show tun0 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d/ -f1)
    # Validar que la IP sea del rango Tailscale (100.64.0.0/10)
    if [[ "${TS_IP}" =~ ^100\.([6-9][4-9]|1[0-1][0-9]|12[0-7])\. ]]; then
        TS_IF="tun0"
        log_ok "Tailscale (app Play Store) detectada: ${TS_IF} (${TS_IP})"
    else
        # tun0 existe pero no parece ser Tailscale
        log_warn "Interfaz tun0 presente pero IP ${TS_IP} no parece Tailscale"
    fi
else
    log_fail "No se detectó interfaz Tailscale (ni tailscale0 ni tun0 con IP 100.x)"
fi

# ─── 2. Tailscale CLI daemon ────────────────────
if pgrep -x tailscaled >/dev/null 2>&1; then
    log_ok "Tailscale CLI (tailscaled) corriendo — PID: $(pgrep -x tailscaled)"
else
    log_info "Tailscale CLI (tailscaled) no está activo — se usa app oficial de Android"
fi

# ─── 3. Rutas Tailscale ─────────────────────────
if [ -n "$TS_IF" ]; then
    TS_ROUTES=$(ip route show table all 2>/dev/null | grep -c "dev ${TS_IF}" || echo 0)
    if [ "$TS_ROUTES" -gt 0 ]; then
        log_ok "Rutas Tailscale activas: ${TS_ROUTES} rutas vía ${TS_IF}"
    else
        log_warn "No se detectaron rutas Tailscale — podría ser un nodo solitario"
    fi
else
    log_warn "No se verificaron rutas (sin interfaz detectada)"
fi

echo ""
# ─── 4. tinyproxy ───────────────────────────────
TINY_PID=""
if pgrep -x tinyproxy >/dev/null 2>&1; then
    TINY_PID=$(pgrep -x tinyproxy)
    log_ok "tinyproxy CORRIENDO (PID: ${TINY_PID})"
else
    log_fail "tinyproxy DETENIDO"
fi

# ─── 5. Proxy local responde ────────────────────
if [ -n "$TINY_PID" ]; then
    if curl -s -o /dev/null -w "%{http_code}" --connect-timeout 3 -x http://127.0.0.1:8888 http://httpbin.org/get 2>/dev/null | grep -q "200\|403\|407"; then
        log_ok "tinyproxy responde en 127.0.0.1:8888"
    else
        # Si httpbin falla, probamos con un HEAD simple
        if curl -s -o /dev/null --connect-timeout 3 -x http://127.0.0.1:8888 -I http://127.0.0.1:8888 2>/dev/null; then
            log_ok "tinyproxy responde (respuesta local)"
        else
            log_warn "tinyproxy no responde en 127.0.0.1:8888 (¿config ok?)"
        fi
    fi
else
    log_warn "tinyproxy no responde (no está corriendo)"
fi

# ─── 6. Conectividad Tailscale DNS ──────────────
if [ -n "$TS_IF" ]; then
    if ping -c 1 -W 3 100.100.100.100 >/dev/null 2>&1; then
        log_ok "DNS Tailscale (100.100.100.100) alcanzable"
    else
        log_warn "No se pudo alcanzar 100.100.100.100 (DNS Tailscale)"
    fi
else
    log_warn "Conectividad Tailscale DNS no verificada (sin interfaz)"
fi

# ─── 7. Conectividad a internet ──────────────────
if ping -c 1 -W 3 1.1.1.1 >/dev/null 2>&1; then
    log_ok "Internet alcanzable (1.1.1.1)"
else
    if ping -c 1 -W 3 8.8.8.8 >/dev/null 2>&1; then
        log_ok "Internet alcanzable (8.8.8.8)"
    else
        log_fail "Sin conectividad a internet"
    fi
fi

# ─── 8. Proxy visible por Tailscale ─────────────
if [ -n "$TS_IP" ] && [ -n "$TINY_PID" ]; then
    # Probar un curl a la IP de Tailscale local — si el proxy escucha en 0.0.0.0, debería responder
    if curl -s -o /dev/null --connect-timeout 3 -x "http://${TS_IP}:8888" -I http://127.0.0.1 2>/dev/null; then
        log_ok "Proxy accesible por Tailscale: http://${TS_IP}:8888"
    else
        log_warn "Proxy no responde por ${TS_IP}:8888 (¿app Tailscale conectada?)"
    fi
else
    log_info "Proxy Tailscale no verificado (falta IP o proxy no activo)"
fi

# ─── 9. Estadísticas rápidas de la interfaz ─────
if [ -n "$TS_IF" ]; then
    echo ""
    log_info "Estadísticas ${TS_IF}:"
    ip -s link show "${TS_IF}" 2>/dev/null | grep -E "^(    |\\s+RX:|\\s+TX:)" | sed 's/^/      /'
fi

# ─── Resumen ────────────────────────────────────
echo ""
echo "══════════════════════════════════════════════════"
echo -e "         RESUMEN: ${GREEN}${OK} OK${NC}  ${YELLOW}${WARN} WARN${NC}  ${RED}${FAIL} FAIL${NC}"
echo "══════════════════════════════════════════════════"

if [ "$FAIL" -eq 0 ]; then
    echo -e "${GREEN}Todo está en orden 🚀${NC}"
    exit 0
elif [ "$FAIL" -le 2 ]; then
    echo -e "${YELLOW}Hay advertencias — revisá los items arriba${NC}"
    exit 1
else
    echo -e "${RED}Hay problemas críticos — revisá la configuración${NC}"
    exit 2
fi
